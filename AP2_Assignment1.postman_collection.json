          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust-002\",\n  \"item_name\": \"Sports Car\",\n  \"amount\": 500000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{order_url}}/orders",
              "host": [
                "{{order_url}}"
              ],
              "path": [
                "orders"
              ]
            }
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{order_url}}/orders/:id",
              "host": [
                "{{order_url}}"
              ],
              "path": [
                "orders", ":id"
              ]
            }
          }
        },
        {
          "name": "Cancel order",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{order_url}}/orders/:id/cancel",
              "host": [
                "{{order_url}}"
              ],
              "path": [
                "orders", ":id", "cancel"
              ]
            }
          }
        },
        {
          "name": "Create order with Idempotency-Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "my-idempotency-key"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust-003\",\n  \"item_name\": \"Tablet\",\n  \"amount\": 20000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{order_url}}/orders",
              "host": [
                "{{order_url}}"
              ],
              "path": [
                "orders"
              ]
            }
          }
        }
